# Application
NEXT_PUBLIC_APP_NAME="Smart LMS"
NEXT_PUBLIC_APP_VERSION="1.0.0"
NEXT_PUBLIC_APP_ENV="development"

# API Configuration
NEXT_PUBLIC_API_BASE_URL="http://localhost:4000/api"
NEXT_PUBLIC_API_VERSION="v1"
NEXT_PUBLIC_API_TIMEOUT=30000

# Authentication
NEXT_PUBLIC_JWT_SECRET="your-jwt-secret-key"
JWT_REFRESH_TOKEN_SECRET="your-refresh-token-secret"
NEXT_PUBLIC_SESSION_TIMEOUT=3600000

# Database (for API routes if needed)
DATABASE_URL="mysql://user:password@localhost:3306/lms_db"

# External Services
NEXT_PUBLIC_UPLOAD_MAX_SIZE=10485760
NEXT_PUBLIC_ALLOWED_FILE_TYPES="image/*,video/*,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document"

# AI Services
NEXT_PUBLIC_AI_API_URL="http://localhost:8000/api"
AI_API_KEY="your-ai-api-key"

# Video Services
NEXT_PUBLIC_VIDEO_CALL_API_URL="your-video-api-url"
VIDEO_CALL_API_KEY="your-video-api-key"

# Email Services (for API routes)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# Redis (for caching)
REDIS_URL="redis://localhost:6379"

# Analytics
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID="GA_MEASUREMENT_ID"

# Feature Flags
NEXT_PUBLIC_ENABLE_CHAT=true
NEXT_PUBLIC_ENABLE_VIDEO_CALLS=true
NEXT_PUBLIC_ENABLE_AI_FEATURES=true
NEXT_PUBLIC_ENABLE_OFFLINE_MODE=false

# Development
NEXT_PUBLIC_DEBUG_MODE=true
NEXT_PUBLIC_MOCK_API=false